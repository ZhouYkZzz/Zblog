generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String
  content     String
  coverImage  String
  category    String
  tagsCsv     String
  featured    Boolean  @default(false)
  publishedAt DateTime
  updatedAt   DateTime @updatedAt
}

model Paper {
  id          String      @id @default(cuid())
  externalId  String?     @unique
  title       String
  authorsCsv  String
  abstract    String
  url         String
  pdfUrl      String?
  source      String
  category    String
  tagsCsv     String
  year        Int?
  isFavorite  Boolean     @default(false)
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  notes       PaperNote[]
}

model PaperNote {
  id               String   @id @default(cuid())
  paperId          String
  researchQuestion String
  method           String
  result           String
  reproducibleCode String
  takeaway         String
  relatedTopic     String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  paper            Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)
}

model SubscriptionSource {
  id          String   @id @default(cuid())
  name        String
  kind        String
  url         String
  keywordsCsv String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RadarSnapshot {
  id          String   @id @default(cuid())
  source      String
  title       String
  summary     String
  url         String
  category    String
  score       Int      @default(0)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
}
